{
  "openapi": "3.1.0",
  "info": { "title": "OpenAPI definition", "version": "v0" },
  "servers": [{ "url": "http://localhost:8088", "description": "Generated server url" }],
  "tags": [
    { "name": "Plates", "description": "Operations for managing plates on the sushi belt" },
    { "name": "Seats", "description": "Operations for seat occupancy and ordering" },
    { "name": "Menu Items", "description": "Operations for managing menu items" },
    { "name": "Belts", "description": "Operations for managing belts" },
    { "name": "Orders", "description": "Operations for listing orders" }
  ],
  "paths": {
    "/api/v1/seats/{id}/order-lines": {
      "post": {
        "tags": ["Seats"],
        "summary": "Pick a plate (create an order line)",
        "description": "Picks the given plate from the belt and adds it as an order line to the current open order of the seat. Fails if the seat is not occupied or the plate is not pickable.",
        "operationId": "pickPlate",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/PickPlateRequest" } }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Plate picked and order line created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/SeatOrderDto" } }
            }
          },
          "400": {
            "description": "Invalid parameter (e.g., id is not a UUID) or validation failed",
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/ProblemDetail" }
              }
            }
          },
          "404": {
            "description": "Seat not found (or referenced plate not found)",
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/ProblemDetail" }
              }
            }
          },
          "409": {
            "description": "Seat not occupied or plate not pickable",
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/ProblemDetail" }
              }
            }
          },
          "500": {
            "description": "Unexpected server error",
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/ProblemDetail" }
              }
            }
          }
        }
      }
    },
    "/api/v1/seats/{id}/occupy": {
      "post": {
        "tags": ["Seats"],
        "summary": "Occupy a seat (create an open order)",
        "description": "Creates a new open order and assigns it to the given seat. Fails if the seat is already occupied.",
        "operationId": "occupySeat",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "201": {
            "description": "Seat occupied and new order created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/SeatStateDto" } }
            }
          },
          "400": {
            "description": "Invalid parameter (e.g., id is not a UUID)",
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/ProblemDetail" }
              }
            }
          },
          "404": {
            "description": "Seat not found",
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/ProblemDetail" }
              }
            }
          },
          "409": {
            "description": "Seat already occupied",
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/ProblemDetail" }
              }
            }
          },
          "500": {
            "description": "Unexpected server error",
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/ProblemDetail" }
              }
            }
          }
        }
      }
    },
