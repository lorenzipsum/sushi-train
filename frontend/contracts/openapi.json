    "/api/v1/belts/{id}/plates": {
      "post": {
        "tags": ["Belts"],
        "summary": "Create plates and place them on the belt",
        "description": "Creates the given number of plates and assigns them immediately to free belt slots. Requires enough free slots; also enforces a minimum gap of 5 slots between placed plates.",
