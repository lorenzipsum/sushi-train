          "menuItemName": { "type": "string" },
          "plateTier": { "type": "string", "enum": ["GREEN", "RED", "GOLD", "BLACK"] },
          "price": { "type": "integer", "format": "int32" }
        }
      },
      "OrderSummaryDto": {
        "type": "object",
        "properties": {
          "orderId": { "type": "string", "format": "uuid" },
          "seatId": { "type": "string", "format": "uuid" },
          "status": { "type": "string", "enum": ["OPEN", "CHECKED_OUT", "CANCELED"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "closedAt": { "type": "string", "format": "date-time" },
          "lines": { "type": "array", "items": { "$ref": "#/components/schemas/OrderLineDto" } },
          "totalPrice": { "type": "integer", "format": "int32" }
        }
      },
      "SeatOrderDto": {
        "type": "object",
        "properties": {
          "seatId": { "type": "string", "format": "uuid" },
          "label": { "type": "string" },
          "positionIndex": { "type": "integer", "format": "int32" },
          "isOccupied": { "type": "boolean" },
          "orderSummary": { "$ref": "#/components/schemas/OrderSummaryDto" }
        }
      },
      "ProblemDetail": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "status": { "type": "integer", "format": "int32" },
          "detail": { "type": "string" },
          "instance": { "type": "string", "format": "uri" },
          "properties": { "type": "object", "additionalProperties": {} }
        }
      },
      "SeatStateDto": {
        "type": "object",
        "properties": {
          "seatId": { "type": "string", "format": "uuid" },
          "label": { "type": "string" },
          "positionIndex": { "type": "integer", "format": "int32" },
          "isOccupied": { "type": "boolean" }
        }
      },
      "CreatePlateRequest": {
        "type": "object",
        "properties": {
          "menuItemId": {
            "type": "string",
            "format": "uuid",
            "description": "Menu item id the plate refers to",
            "example": "11111111-1111-1111-1111-111111111111"
          },
          "tierSnapshot": {
            "type": "string",
            "description": "Optional tier snapshot. If omitted, service can derive from menu item.",
            "enum": ["GREEN", "RED", "GOLD", "BLACK"],
            "example": "RED"
          },
          "priceAtCreation": {
            "type": "integer",
            "format": "int32",
            "description": "Optional price in Yen at creation time. If omitted, service can derive from menu item.",
            "example": 500,
            "minimum": 1
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "Optional expiration timestamp (UTC). If omitted, service can compute default TTL.",
            "example": "2026-01-19T15:22:08.485369100Z"
          }
        },
        "required": ["menuItemId"]
      },
      "PlateDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "menuItemId": { "type": "string", "format": "uuid" },
          "tierSnapshot": { "type": "string", "enum": ["GREEN", "RED", "GOLD", "BLACK"] },
          "priceAtCreation": { "type": "integer", "format": "int32" },
          "createdAt": { "type": "string", "format": "date-time" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "status": { "type": "string", "enum": ["CREATED", "ON_BELT", "PICKED", "EXPIRED"] }
        },
        "required": [
          "createdAt",
          "expiresAt",
          "id",
          "menuItemId",
          "priceAtCreation",
          "status",
          "tierSnapshot"
        ]
      },
      "CreatePlateAndPlaceOnBeltRequest": {
        "type": "object",
        "properties": {
          "menuItemId": { "type": "string", "format": "uuid" },
          "numOfPlates": { "type": "integer", "format": "int32", "minimum": 1 },
          "tierSnapshot": { "type": "string", "enum": ["GREEN", "RED", "GOLD", "BLACK"] },
          "priceAtCreation": { "type": "integer", "format": "int32", "minimum": 0 },
          "expiresAt": { "type": "string", "format": "date-time" }
        },
        "required": ["menuItemId"]
      },
      "CreatedPlatesOnBeltResponse": {
        "type": "object",
        "properties": {
          "beltId": { "type": "string", "format": "uuid" },
          "createdCount": { "type": "integer", "format": "int32" },
          "placedPlates": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PlacedPlateDto" }
          }
        }
      },
      "PlacedPlateDto": {
        "type": "object",
        "properties": {
          "plateId": { "type": "string", "format": "uuid" },
          "slotId": { "type": "string", "format": "uuid" },
          "slotPositionIndex": { "type": "integer", "format": "int32" },
          "menuItemId": { "type": "string", "format": "uuid" },
          "expiresAt": { "type": "string", "format": "date-time" }
        }
      },
      "BeltUpdateRequest": {
        "type": "object",
        "description": "Partial update for belt settings. Omit a field (null) to keep its current value. At least one field must be provided.",
        "properties": {
          "tickIntervalMs": {
            "type": "integer",
            "format": "int32",
            "description": "Tick interval in milliseconds. Lower = more frequent ticks (potentially higher load). Omit to keep current value.",
            "example": 750,
            "maximum": 5000,
            "minimum": 100
          },
          "speedSlotsPerTick": {
            "type": "integer",
            "format": "int32",
            "description": "Belt speed measured as slots moved per tick. Higher = faster belt. Omit to keep current value.",
            "example": 2,
            "maximum": 5,
            "minimum": 0
          }
        }
      },
      "BeltParamsDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "tickIntervalMs": { "type": "integer", "format": "int32" },
          "speedSlotsPerTick": { "type": "integer", "format": "int32" }
        }
      },
      "PageMetadata": {
        "type": "object",
        "properties": {
          "size": { "type": "integer", "format": "int64" },
          "number": { "type": "integer", "format": "int64" },
          "totalElements": { "type": "integer", "format": "int64" },
          "totalPages": { "type": "integer", "format": "int64" }
        }
      },
      "PagedModel": {
        "type": "object",
        "properties": {
          "content": { "type": "array", "items": {} },
          "page": { "$ref": "#/components/schemas/PageMetadata" }
        }
      },
      "MenuItemDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "defaultTier": { "type": "string", "enum": ["GREEN", "RED", "GOLD", "BLACK"] },
          "basePrice": { "type": "integer", "format": "int32" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["basePrice", "createdAt", "defaultTier", "id", "name"]
      },
      "BeltDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "slotCount": { "type": "integer", "format": "int32" },
          "baseRotationOffset": { "type": "integer", "format": "int32" },
          "tickIntervalMs": { "type": "integer", "format": "int32" },
          "speedSlotsPerTick": { "type": "integer", "format": "int32" },
          "offsetStartedAt": { "type": "string", "format": "date-time" }
        }
      },
      "BeltSlotDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "positionIndex": { "type": "integer", "format": "int32" },
          "plateId": { "type": "string", "format": "uuid" }
        }
      },
      "FullBeltDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "slotCount": { "type": "integer", "format": "int32" },
          "baseRotationOffset": { "type": "integer", "format": "int32" },
          "tickIntervalMs": { "type": "integer", "format": "int32" },
          "speedSlotsPerTick": { "type": "integer", "format": "int32" },
          "slots": { "type": "array", "items": { "$ref": "#/components/schemas/BeltSlotDto" } },
          "seats": { "type": "array", "items": { "$ref": "#/components/schemas/SeatDto" } },
          "offsetStartedAt": { "type": "string", "format": "date-time" }
        }
      },
      "SeatDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "positionIndex": { "type": "integer", "format": "int32" },
          "label": { "type": "string" }
        }
      },
      "BeltSlotSnapshotDto": {
        "type": "object",
        "properties": {
          "slotId": { "type": "string", "format": "uuid" },
          "positionIndex": { "type": "integer", "format": "int32" },
          "plate": { "$ref": "#/components/schemas/PlateSnapshotDto" }
        }
      },
      "BeltSnapshotDto": {
        "type": "object",
        "properties": {
          "beltId": { "type": "string", "format": "uuid" },
          "beltName": { "type": "string" },
          "beltSlotCount": { "type": "integer", "format": "int32" },
          "beltBaseRotationOffset": { "type": "integer", "format": "int32" },
          "beltOffsetStartedAt": { "type": "string", "format": "date-time" },
          "beltTickIntervalMs": { "type": "integer", "format": "int32" },
          "beltSpeedSlotsPerTick": { "type": "integer", "format": "int32" },
          "slots": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BeltSlotSnapshotDto" }
          }
        }
      },
      "PlateSnapshotDto": {
        "type": "object",
        "properties": {
          "plateId": { "type": "string", "format": "uuid" },
          "menuItemId": { "type": "string", "format": "uuid" },
          "menuItemName": { "type": "string" },
          "tier": { "type": "string", "enum": ["GREEN", "RED", "GOLD", "BLACK"] },
          "priceAtCreation": { "$ref": "#/components/schemas/YenAmount" },
          "status": { "type": "string", "enum": ["CREATED", "ON_BELT", "PICKED", "EXPIRED"] },
          "expiresAt": { "type": "string", "format": "date-time" }
        }
      },
      "YenAmount": {
        "type": "object",
        "properties": {
          "amount": { "type": "integer", "format": "int32" },
          "zero": { "type": "boolean" }
        }
      }
    }
  }
}
