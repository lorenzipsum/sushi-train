<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Provides CONSOLE_LOG_PATTERN, PID, colors (%clr), exception formatting, etc. -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Pull root level from application*.yaml (logging.level.root) -->
    <springProperty scope="context" name="ROOT_LEVEL" source="logging.level.root" defaultValue="INFO"/>

    <!-- show-sql profile: same console layout, plus your TxSqlNoiseFilter -->
    <springProfile name="show-sql">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <filter class="com.lorenzipsum.sushitrain.backend.config.logging.TxSqlNoiseFilter"/>
            <encoder>
                <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <root level="${ROOT_LEVEL}">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- default (everything except show-sql): Spring Boot look, no filter -->
    <springProfile name="!show-sql">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <root level="${ROOT_LEVEL}">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>