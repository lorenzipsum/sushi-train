subscription_id      = "00000000-0000-0000-0000-000000000000"
location            = "switzerlandnorth"
project_name        = "sushi-train"
environment_name    = "dev"
resource_name_prefix = "sushitrain"
container_registry_name = "sushitraindevacr2026a"
container_registry_sku = "Basic"
container_registry_admin_enabled = false
postgresql_server_name = "sushitrain-dev-pg-2026a"
postgresql_version = "17"
postgresql_administrator_login = "sushitrainadmin"
# Set this in your local terraform.tfvars or via TF_VAR_postgresql_administrator_password.
# postgresql_administrator_password = "replace-with-a-strong-password"
postgresql_database_name = "sushitrain"
postgresql_sku_name = "B_Standard_B1ms"
postgresql_storage_mb = 32768
postgresql_backup_retention_days = 7
postgresql_public_network_access_enabled = true
postgresql_allow_azure_services = true
log_analytics_workspace_sku = "PerGB2018"
log_analytics_retention_days = 30
backend_image_repository = "sushi-train-backend"
backend_image_tag = "dev-latest"
backend_container_cpu = 0.5
backend_container_memory = "1Gi"
backend_min_replicas = 1
backend_max_replicas = 1
backend_ingress_external_enabled = true
backend_target_port = 8080
backend_swagger_enabled = false
backend_database_user_override = ""
frontend_image_repository = "sushi-train-frontend"
frontend_image_tag = "dev-latest"
frontend_container_cpu = 0.25
frontend_container_memory = "0.5Gi"
frontend_min_replicas = 1
frontend_max_replicas = 1
frontend_ingress_external_enabled = true
frontend_target_port = 80
frontend_api_upstream_scheme = "https"

tags = {
  owner   = "personal"
  purpose = "learning"
}